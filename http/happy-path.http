@baseUrl = http://localhost:8080
@username = admin
@password = change-me

# installmentNumber in prepayment requests means the last fully paid installment
# after which the prepayment is applied.

### 1) Login and get JWT
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

### 2) Create base loan
# @name createLoan
POST {{baseUrl}}/api/loans
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "principal": 1000000,
  "annualInterestRate": 12.0,
  "tenureMonths": 60,
  "startDate": "2026-01-01"
}

### 3) Get loan by id
GET {{baseUrl}}/api/loans/{{createLoan.response.body.$.id}}
Authorization: Bearer {{login.response.body.$.token}}

### 4) Get schedule for current loan
GET {{baseUrl}}/api/loans/{{createLoan.response.body.$.id}}/schedule
Authorization: Bearer {{login.response.body.$.token}}

### 5) Category A - Option A (Reduce EMI, Keep Tenor)
POST {{baseUrl}}/api/loans/{{createLoan.response.body.$.id}}/prepayments
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "installmentNumber": 24,
  "amount": 200000,
  "option": "REDUCE_EMI_KEEP_TENOR"
}

### 6) Category A - Option B (Reduce Tenor, Keep EMI)
# Create another loan first so this option is tested independently
# @name createLoanOptionB
POST {{baseUrl}}/api/loans
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "principal": 1000000,
  "annualInterestRate": 12.0,
  "tenureMonths": 60,
  "startDate": "2026-01-01"
}

### Apply Option B prepayment
POST {{baseUrl}}/api/loans/{{createLoanOptionB.response.body.$.id}}/prepayments
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "installmentNumber": 24,
  "amount": 200000,
  "option": "REDUCE_TENOR_KEEP_EMI"
}

### 7) Category A - Option C (Advance Installments)
# Create another loan first so this option is tested independently
# @name createLoanOptionC
POST {{baseUrl}}/api/loans
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "principal": 1000000,
  "annualInterestRate": 12.0,
  "tenureMonths": 60,
  "startDate": "2026-01-01"
}

### Apply Option C prepayment
POST {{baseUrl}}/api/loans/{{createLoanOptionC.response.body.$.id}}/prepayments
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "installmentNumber": 24,
  "amount": 200000,
  "option": "ADVANCE_INSTALLMENTS"
}
