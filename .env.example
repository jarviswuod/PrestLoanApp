# Copy this file to .env for local development only.
# Never commit real credentials or secrets.

# Database
DB_URL=jdbc:mysql://localhost:3306/prestloan
DB_USERNAME=prestloan
DB_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Authentication bootstrap user
APP_SECURITY_USERNAME=admin
APP_SECURITY_PASSWORD=change-me

# JWT
# Use at least 32+ random bytes represented as base64 or a strong random string.
APP_JWT_SECRET=replace-with-strong-secret
APP_JWT_EXPIRATION_MINUTES=120
